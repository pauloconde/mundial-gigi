  :global(#bases-content h2) { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; color: var(--text-primary); }
  :global(#bases-content h3) { font-size: 1.125rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--text-primary); }
  :global(#bases-content p) { margin-bottom: 1rem; line-height: 1.6; }
  :global(#bases-content ul) { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
  :global(#bases-content ol) { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1rem; }
  :global(#bases-content li) { margin-bottom: 0.5rem; }
  :global(#bases-content a) { color: var(--brand-nav-icon-active, #f59e0b); text-decoration: underline; }
