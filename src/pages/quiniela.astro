---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import sponsorInfo from '../data/sponsor.json';
import { TEAM_ES, getFlagUrl } from '../lib/worldcup';

if (!sponsorInfo.hasQuiniela) {
  return Astro.redirect('/');
}

const basesPath = path.join(process.cwd(), 'public', 'bases.md');
const hasBases = fs.existsSync(basesPath);

const now = new Date();
const endDate = new Date(sponsorInfo.quinielaEndDate || '2026-06-11T23:59:00Z');
const isClosed = now > endDate;

// Use TEAM_ES which contains exactly the 48 participating countries
const teams = Object.entries(TEAM_ES)
  .map(([id, name]) => ({ id, name, flag: getFlagUrl(id) }))
  .sort((a, b) => a.name.localeCompare(b.name));

// Fixed Match configurations
const isFixed = !!sponsorInfo.FixedMatchEnabled;
const fixedTeamA = sponsorInfo.FixedMatchTeamA || '';
const fixedTeamB = sponsorInfo.FixedMatchTeamB || '';
const flagA = fixedTeamA ? getFlagUrl(fixedTeamA) : 'data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=';
const flagB = fixedTeamB ? getFlagUrl(fixedTeamB) : 'data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=';
const showPredictFinalScore = sponsorInfo.quinielaPredictFinalScore || isFixed;
const showThirdPlace = sponsorInfo.includeThirdPlacePrediction && !isFixed;
---

<Layout title="Quiniela" page="quiniela">
  <section class="px-4 pt-8 pb-10 text-center relative overflow-hidden min-h-screen">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full opacity-10"
           style="background: radial-gradient(circle, var(--brand-nav-icon-active, #f59e0b), transparent 70%);"></div>
      <div class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full opacity-10"
           style="background: radial-gradient(circle, var(--brand-nav-icon, #6366f1), transparent 70%);"></div>
    </div>

    <div class="relative z-10 max-w-lg mx-auto pb-24">
      <div class="flex items-center justify-center mb-2">
        <h1 class="font-['Outfit'] font-black text-3xl text-[var(--text-primary)]">{sponsorInfo.quinielaTitle || '⚽ Gran Quiniela 🏆'}</h1>
      </div>
      <p class="text-[var(--text-secondary)] text-sm mb-6 px-4">{sponsorInfo.quinielaDescription || 'Acierta el 1er y 2do lugar del Mundial y gana increíbles premios con nosotros.'}</p>

      {sponsorInfo.quinielaPrizeImage && (
        <div class="mb-6 text-center relative z-10">
          <button type="button" id="open-prize-btn" class="text-[var(--brand-nav-icon-active,#f59e0b)] text-sm font-bold hover:underline transition-all flex items-center justify-center gap-1.5 mx-auto">
            <span>🎁 Ver Premios</span>
          </button>
        </div>
      )}

      {isClosed ? (
        <div class="glass rounded-3xl p-8 mb-8 text-center">
          <p class="text-5xl mb-4">🔒</p>
          <h2 class="font-['Outfit'] font-bold text-xl text-[var(--text-primary)] mb-2">Quiniela Cerrada</h2>
          <p class="text-[var(--text-secondary)] text-sm">La recepción de participaciones ha finalizado. ¡Mucha suerte a todos los participantes!</p>
        </div>
      ) : (
        <div id="quiniela-container" class="glass rounded-3xl p-6 text-left relative shadow-2xl">
          
          <div id="success-message" class="hidden text-center py-8">
            <p class="text-5xl mb-4">🎉</p>
            <h2 class="font-['Outfit'] font-bold text-xl text-[var(--text-primary)] mb-2">¡Participación exitosa!</h2>
            <p class="text-[var(--text-secondary)] text-sm">Tu pronóstico ha sido guardado correctamente. ¡Te deseamos mucha suerte!</p>
          </div>

          <form id="quiniela-form" class="space-y-5" 
                data-sponsor={sponsorInfo.quinielaId}
                data-require-receipt={sponsorInfo.quinielaRequireReceipt ? 'true' : 'false'}
                data-predict-final-score={showPredictFinalScore ? 'true' : 'false'}>
            
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">Cédula de Identidad</label>
              <div class="flex gap-2">
                <select id="cedula-tipo" class="bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-3 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors w-20 appearance-none text-center font-semibold" required>
                  <option value="V-">V</option>
                  <option value="E-">E</option>
                </select>
                <input type="number" id="cedula-num" max="99999999" placeholder="12345678" class="flex-1 bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-4 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors" required />
              </div>
            </div>

            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">Nombre Completo</label>
              <input type="text" id="nombre" placeholder="Ej. Juan Pérez" class="w-full bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-4 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors" required />
            </div>

            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">Email</label>
              <input type="email" id="email" placeholder="correo@ejemplo.com" class="w-full bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-4 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors" required />
            </div>

            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">Teléfono</label>
              <input type="tel" id="telefono" placeholder="Ej. 04141234567" class="w-full bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-4 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors" required />
            </div>

            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">Instagram</label>
              <input type="text" id="instagram" placeholder="@usuario" class="w-full bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-4 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors" required />
            </div>

            {sponsorInfo.quinielaRequireReceipt && (
              <div class="space-y-1.5 animate-[fadeIn_0.3s_ease]">
                <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">🧾 Comprobante de Compra (Factura)</label>
                <div class="relative">
                  <input type="file" id="factura-file" accept="image/*,application/pdf" class="hidden" required />
                  
                  <div id="upload-zone" class="border-2 border-dashed border-[var(--border-subtle)] hover:border-[var(--brand-nav-icon-active,#f59e0b)] rounded-2xl p-6 text-center cursor-pointer transition-all duration-300 flex flex-col items-center justify-center gap-2 group bg-[var(--bg-primary)]/40 hover:bg-[var(--bg-primary)]/80">
                    <div class="w-12 h-12 rounded-full bg-[var(--brand-nav-icon-active,#f59e0b)]/10 text-[var(--brand-nav-icon-active,#f59e0b)] flex items-center justify-center transition-transform group-hover:scale-110 duration-300">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                      </svg>
                    </div>
                    <span class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-nav-icon-active,#f59e0b)] transition-colors">Selecciona tu factura</span>
                    <span class="text-[10px] text-[var(--text-secondary)]">Soporta imágenes (JPG, PNG, WEBP) o PDF hasta 5MB</span>
                  </div>

                  <div id="preview-zone" class="hidden border border-[var(--border-subtle)] rounded-2xl p-4 bg-[var(--bg-primary)]/60 flex items-center justify-between gap-3 animate-[fadeIn_0.2s_ease]">
                    <div class="flex items-center gap-3 overflow-hidden">
                      <div class="w-12 h-12 rounded-xl bg-[var(--border-subtle)]/30 overflow-hidden flex items-center justify-center shrink-0">
                        <img id="preview-image" src="" alt="Vista previa" class="w-full h-full object-cover hidden" />
                        <div id="preview-pdf-icon" class="hidden text-red-400">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                          </svg>
                        </div>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p id="preview-filename" class="text-xs font-semibold text-[var(--text-primary)] truncate">nombre-archivo.pdf</p>
                        <p id="preview-filesize" class="text-[10px] text-[var(--text-secondary)]">0.0 MB</p>
                      </div>
                    </div>
                    <button type="button" id="remove-file-btn" class="w-8 h-8 rounded-full bg-red-500/10 text-red-400 hover:bg-red-500/20 active:scale-95 transition-all flex items-center justify-center shrink-0 cursor-pointer">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            )}

            <div class="h-px w-full bg-[var(--border-subtle)] my-6 opacity-50"></div>

            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">
                {isFixed ? `Goles de ${TEAM_ES[fixedTeamA] || fixedTeamA}` : '🏆 Campeón (1er Lugar)'}
              </label>
              <div class="flex gap-2">
                <div class="flex-1 relative flex items-center bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl focus-within:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors pr-4">
                  <div class="w-12 flex shrink-0 items-center justify-center pl-3 pr-2 border-r border-[var(--border-subtle)]">
                    <img id="flag-primer" src={isFixed ? flagA : "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="} class="w-6 h-4 object-cover rounded-sm" alt="" />
                  </div>
                  <select id="primer-lugar" class="flex-1 bg-transparent px-3 py-3 text-[var(--text-primary)] text-sm outline-none font-medium appearance-none" required disabled={isFixed}>
                    <option value="" disabled selected={!isFixed}>Selecciona el equipo ganador</option>
                    {teams.map(t => (
                      <option value={t.id} data-flag={t.flag} selected={isFixed && t.id === fixedTeamA}>{t.name}</option>
                    ))}
                  </select>
                </div>
                {showPredictFinalScore && (
                  <input type="number" id="primer-lugar-goles" placeholder="Goles" min="0" class="w-24 bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-3 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors text-center font-bold" required />
                )}
              </div>
            </div>

            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">
                {isFixed ? `Goles de ${TEAM_ES[fixedTeamB] || fixedTeamB}` : '🥈 Subcampeón (2do Lugar)'}
              </label>
              <div class="flex gap-2">
                <div class="flex-1 relative flex items-center bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl focus-within:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors pr-4">
                  <div class="w-12 flex shrink-0 items-center justify-center pl-3 pr-2 border-r border-[var(--border-subtle)]">
                    <img id="flag-segundo" src={isFixed ? flagB : "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="} class="w-6 h-4 object-cover rounded-sm" alt="" />
                  </div>
                  <select id="segundo-lugar" class="flex-1 bg-transparent px-3 py-3 text-[var(--text-primary)] text-sm outline-none font-medium appearance-none" required disabled={isFixed}>
                    <option value="" disabled selected={!isFixed}>Selecciona el segundo lugar</option>
                    {teams.map(t => (
                      <option value={t.id} data-flag={t.flag} selected={isFixed && t.id === fixedTeamB}>{t.name}</option>
                    ))}
                  </select>
                </div>
                {showPredictFinalScore && (
                  <input type="number" id="segundo-lugar-goles" placeholder="Goles" min="0" class="w-24 bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl px-3 py-3 text-[var(--text-primary)] text-sm outline-none focus:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors text-center font-bold" required />
                )}
              </div>
            </div>

            {showThirdPlace && (
              <div class="space-y-1.5">
                <label class="text-[10px] font-bold text-[var(--text-primary)] uppercase tracking-wider ml-1">🥉 Tercer Lugar</label>
                <div class="relative flex items-center bg-[var(--bg-primary)] border border-[var(--border-subtle)] rounded-xl focus-within:border-[var(--brand-nav-icon-active,#f59e0b)] transition-colors pr-4">
                  <div class="w-12 flex shrink-0 items-center justify-center pl-3 pr-2 border-r border-[var(--border-subtle)]">
                    <img id="flag-tercer" src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" class="w-6 h-4 object-cover rounded-sm" alt="" />
                  </div>
                  <select id="tercer-lugar" class="flex-1 bg-transparent px-3 py-3 text-[var(--text-primary)] text-sm outline-none font-medium appearance-none" required>
                    <option value="" disabled selected>Selecciona el tercer lugar</option>
                    {teams.map(t => (
                      <option value={t.id} data-flag={t.flag}>{t.name}</option>
                    ))}
                  </select>
                </div>
              </div>
            )}

            <div id="error-message" class="hidden bg-red-500/20 border border-red-500/50 rounded-xl p-3 text-red-200 text-xs text-center font-medium"></div>

            <button type="submit" id="submit-btn" class="w-full mt-6 flex items-center justify-center gap-2 px-6 py-4 rounded-xl font-bold text-sm transition-all active:scale-95 hover:opacity-90 shadow-lg" style="background: var(--brand-nav-icon-active, #f59e0b); color: #fff;">
              <span>Participar Ahora</span>
              <svg id="spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </form>

        </div>
      )}

      {hasBases && (
        <div class="mt-6 text-center relative z-10 pb-8">
          <button type="button" id="open-bases-btn" class="text-[var(--text-secondary)] text-xs font-semibold underline hover:text-[var(--text-primary)] transition-colors">
            Ver Bases del Concurso
          </button>
        </div>
      )}

      {hasBases && (
        <div id="bases-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300">
          <div class="glass w-full max-w-2xl max-h-[80vh] rounded-3xl p-8 flex flex-col relative scale-95 transition-transform duration-300 mx-4 shadow-2xl overflow-hidden border border-[var(--border-subtle)]">
            <button type="button" id="close-bases-btn" class="absolute top-4 right-4 text-[var(--text-secondary)] hover:text-white bg-black/20 rounded-full w-8 h-8 flex items-center justify-center transition-colors z-10">
              ✕
            </button>
            <div id="bases-content" class="overflow-y-auto pr-4 text-sm text-[var(--text-secondary)] text-left">
              <div class="flex items-center justify-center py-10">
                <svg class="w-8 h-8 animate-spin text-[var(--brand-nav-icon-active,#f59e0b)]" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </div>
            </div>
          </div>
        </div>
      )}

      {sponsorInfo.quinielaPrizeImage && (
        <div id="prize-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/95 hidden opacity-0 transition-opacity duration-300">
          <button type="button" id="close-prize-btn" class="absolute top-6 right-6 text-white/70 hover:text-white bg-white/10 hover:bg-white/20 rounded-full w-10 h-10 flex items-center justify-center transition-all z-10 text-lg">
            ✕
          </button>
          <div class="relative max-w-[90vw] max-h-[85vh] transition-transform duration-300 scale-95 flex items-center justify-center">
            <img src={sponsorInfo.quinielaPrizeImage} alt="Premio de la Quiniela" class="max-w-full max-h-[85vh] object-contain rounded-2xl" onerror="this.style.display='none'" />
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  document.addEventListener('DOMContentLoaded', () => {
    // Lógica del modal de Premios
    const openPrizeBtn = document.getElementById('open-prize-btn');
    const closePrizeBtn = document.getElementById('close-prize-btn');
    const prizeModal = document.getElementById('prize-modal');

    if (openPrizeBtn && prizeModal && closePrizeBtn) {
      const closeModal = () => {
        prizeModal.classList.add('opacity-0');
        prizeModal.querySelector('.relative')?.classList.add('scale-95');
        setTimeout(() => prizeModal.classList.add('hidden'), 300);
      };

      openPrizeBtn.addEventListener('click', () => {
        prizeModal.classList.remove('hidden');
        // Forzar reflow
        void prizeModal.offsetWidth;
        prizeModal.classList.remove('opacity-0');
        prizeModal.querySelector('.relative')?.classList.remove('scale-95');
      });

      closePrizeBtn.addEventListener('click', closeModal);
      prizeModal.addEventListener('click', (e) => {
        if (e.target === prizeModal) closeModal();
      });
    }

    // Lógica del modal de Bases
    const openBasesBtn = document.getElementById('open-bases-btn');
    const closeBasesBtn = document.getElementById('close-bases-btn');
    const basesModal = document.getElementById('bases-modal');
    const basesContent = document.getElementById('bases-content');
    
    if (openBasesBtn && basesModal && closeBasesBtn && basesContent) {
      let isLoaded = false;

      const closeModal = () => {
        basesModal.classList.add('opacity-0');
        basesModal.querySelector('.glass')?.classList.add('scale-95');
        setTimeout(() => basesModal.classList.add('hidden'), 300);
      };

      openBasesBtn.addEventListener('click', async () => {
        basesModal.classList.remove('hidden');
        // Forzar reflow
        void basesModal.offsetWidth;
        basesModal.classList.remove('opacity-0');
        basesModal.querySelector('.glass')?.classList.remove('scale-95');
        
        if (!isLoaded) {
          try {
            const [res, markedModule] = await Promise.all([
              fetch('/bases.md'),
              // @ts-ignore
              import('https://cdn.jsdelivr.net/npm/marked/lib/marked.esm.js')
            ]);
            
            if (res.ok) {
              const md = await res.text();
              const { marked } = markedModule;
              basesContent.innerHTML = marked.parse(md);
              isLoaded = true;
            } else {
              basesContent.innerHTML = '<p class="text-center text-red-400">No se pudieron cargar las bases.</p>';
            }
          } catch (err) {
            basesContent.innerHTML = '<p class="text-center text-red-400">Error al cargar las bases.</p>';
          }
        }
      });

      closeBasesBtn.addEventListener('click', closeModal);
      basesModal.addEventListener('click', (e) => {
        if (e.target === basesModal) closeModal();
      });
    }

    const form = document.getElementById('quiniela-form') as HTMLFormElement;
    if (!form) return;

    // Elementos de la factura
    const facturaInput = document.getElementById('factura-file') as HTMLInputElement | null;
    const uploadZone = document.getElementById('upload-zone');
    const previewZone = document.getElementById('preview-zone');
    const previewImage = document.getElementById('preview-image') as HTMLImageElement | null;
    const previewPdfIcon = document.getElementById('preview-pdf-icon');
    const previewFilename = document.getElementById('preview-filename');
    const previewFilesize = document.getElementById('preview-filesize');
    const removeFileBtn = document.getElementById('remove-file-btn');
    let selectedFile: File | null = null;

    if (uploadZone && facturaInput) {
      uploadZone.addEventListener('click', () => {
        facturaInput.click();
      });

      facturaInput.addEventListener('change', () => {
        if (facturaInput.files && facturaInput.files[0]) {
          handleFile(facturaInput.files[0]);
        }
      });

      // Eventos drag and drop
      ['dragenter', 'dragover'].forEach(eventName => {
        uploadZone.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
          uploadZone.classList.add('border-[var(--brand-nav-icon-active,#f59e0b)]');
          uploadZone.classList.add('bg-[var(--bg-primary)]/80');
        }, false);
      });

      ['dragleave', 'drop'].forEach(eventName => {
        uploadZone.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
          uploadZone.classList.remove('border-[var(--brand-nav-icon-active,#f59e0b)]');
          uploadZone.classList.remove('bg-[var(--bg-primary)]/80');
        }, false);
      });

      uploadZone.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        if (dt && dt.files && dt.files[0]) {
          handleFile(dt.files[0]);
        }
      });
    }

    function handleFile(fileObj: File) {
      const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif', 'application/pdf'];
      if (!allowedTypes.includes(fileObj.type)) {
        showError("Formato de archivo no válido. Solo se permiten imágenes o PDFs.");
        if (facturaInput) facturaInput.value = '';
        return;
      }

      const maxSize = 5 * 1024 * 1024; // 5MB
      if (fileObj.size > maxSize) {
        showError("El archivo supera el tamaño máximo permitido de 5MB.");
        if (facturaInput) facturaInput.value = '';
        return;
      }

      hideError();
      selectedFile = fileObj;

      if (previewFilename) previewFilename.textContent = fileObj.name;
      if (previewFilesize) previewFilesize.textContent = (fileObj.size / (1024 * 1024)).toFixed(2) + " MB";

      if (fileObj.type.startsWith('image/')) {
        if (previewImage) {
          previewImage.src = URL.createObjectURL(fileObj);
          previewImage.classList.remove('hidden');
        }
        if (previewPdfIcon) previewPdfIcon.classList.add('hidden');
      } else if (fileObj.type === 'application/pdf') {
        if (previewImage) {
          previewImage.classList.add('hidden');
          previewImage.src = '';
        }
        if (previewPdfIcon) previewPdfIcon.classList.remove('hidden');
      }

      uploadZone?.classList.add('hidden');
      previewZone?.classList.remove('hidden');
    }

    if (removeFileBtn) {
      removeFileBtn.addEventListener('click', () => {
        selectedFile = null;
        if (facturaInput) facturaInput.value = '';
        previewZone?.classList.add('hidden');
        uploadZone?.classList.remove('hidden');
        if (previewImage && previewImage.src.startsWith('blob:')) {
          URL.revokeObjectURL(previewImage.src);
          previewImage.src = '';
        }
      });
    }

    const errorDiv = document.getElementById('error-message');
    const successDiv = document.getElementById('success-message');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const spinner = document.getElementById('spinner');

    const primerSelect = document.getElementById('primer-lugar') as HTMLSelectElement;
    const segundoSelect = document.getElementById('segundo-lugar') as HTMLSelectElement;
    const tercerSelect = document.getElementById('tercer-lugar') as HTMLSelectElement | null;

    // Prevenir seleccionar el mismo país en ambos lugares y actualizar banderas
    const updateDropdowns = () => {
      const pVal = primerSelect.value;
      const sVal = segundoSelect.value;
      const tVal = tercerSelect ? tercerSelect.value : null;

      // Actualizar banderas
      const pFlag = primerSelect.options[primerSelect.selectedIndex]?.dataset.flag;
      const sFlag = segundoSelect.options[segundoSelect.selectedIndex]?.dataset.flag;
      const tFlag = tercerSelect ? tercerSelect.options[tercerSelect.selectedIndex]?.dataset.flag : null;
      
      const pImg = document.getElementById('flag-primer') as HTMLImageElement;
      const sImg = document.getElementById('flag-segundo') as HTMLImageElement;
      const tImg = document.getElementById('flag-tercer') as HTMLImageElement | null;
      
      if (pImg && pFlag) pImg.src = pFlag;
      if (sImg && sFlag) sImg.src = sFlag;
      if (tImg && tFlag) tImg.src = tFlag;

      // Habilitar todas las opciones
      Array.from(primerSelect.options).forEach(opt => opt.disabled = false);
      Array.from(segundoSelect.options).forEach(opt => opt.disabled = false);
      if (tercerSelect) {
        Array.from(tercerSelect.options).forEach(opt => opt.disabled = false);
      }

      // Deshabilitar la primera opción (placeholder)
      primerSelect.options[0].disabled = true;
      segundoSelect.options[0].disabled = true;
      if (tercerSelect) tercerSelect.options[0].disabled = true;

      // Deshabilitar el seleccionado en las otras listas
      const selectedValues = [pVal, sVal, tVal].filter(Boolean);
      selectedValues.forEach(val => {
        if (val !== pVal) {
          const opt = primerSelect.querySelector(`option[value="${val}"]`) as HTMLOptionElement;
          if (opt) opt.disabled = true;
        }
        if (val !== sVal) {
          const opt = segundoSelect.querySelector(`option[value="${val}"]`) as HTMLOptionElement;
          if (opt) opt.disabled = true;
        }
        if (tercerSelect && val !== tVal) {
          const opt = tercerSelect.querySelector(`option[value="${val}"]`) as HTMLOptionElement;
          if (opt) opt.disabled = true;
        }
      });
    };

    primerSelect.addEventListener('change', () => { hideError(); updateDropdowns(); });
    segundoSelect.addEventListener('change', () => { hideError(); updateDropdowns(); });
    if (tercerSelect) tercerSelect.addEventListener('change', () => { hideError(); updateDropdowns(); });

    // Inicializar banderas y deshabilitar opciones repetidas en carga inicial
    updateDropdowns();

    function showError(msg: string) {
      if (errorDiv) {
        errorDiv.textContent = msg;
        errorDiv.classList.remove('hidden');
      }
    }

    function hideError() {
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      if (primerSelect.value === segundoSelect.value || (tercerSelect && (tercerSelect.value === primerSelect.value || tercerSelect.value === segundoSelect.value))) {
        showError("Los países seleccionados no pueden repetirse.");
        return;
      }

      const sponsorId = form.dataset.sponsor;
      const requireReceipt = form.dataset.requireReceipt === 'true';
      const predictFinalScore = form.dataset.predictFinalScore === 'true';

      const cedulaTipo = (document.getElementById('cedula-tipo') as HTMLSelectElement).value;
      const cedulaNum = (document.getElementById('cedula-num') as HTMLInputElement).value;
      const cedula = cedulaTipo + cedulaNum;
      
      const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const telefono = (document.getElementById('telefono') as HTMLInputElement).value;
      const instagram = (document.getElementById('instagram') as HTMLInputElement).value;
      const primer_lugar = primerSelect.value;
      const segundo_lugar = segundoSelect.value;
      const tercer_lugar = tercerSelect ? tercerSelect.value : null;

      let factura_image: string | null = null;
      let uploadedFileName: string | null = null;

      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.7';
      spinner?.classList.remove('hidden');

      try {
        if (requireReceipt) {
          if (!selectedFile) {
            showError("Por favor, selecciona tu comprobante de compra.");
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
            spinner?.classList.add('hidden');
            return;
          }

          // Subir a storage
          const fileExt = selectedFile.name.split('.').pop();
          const randomStr = Math.random().toString(36).substring(2, 15);
          const fileName = `${cedula.replace(/[^a-zA-Z0-9]/g, '')}-${Date.now()}-${randomStr}.${fileExt}`;

          const { data: uploadData, error: uploadError } = await supabase.storage
            .from('facturas')
            .upload(fileName, selectedFile);

          if (uploadError) {
            console.error("Storage upload error:", uploadError);
            showError("Error al subir el comprobante. Por favor, intenta de nuevo.");
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
            spinner?.classList.add('hidden');
            return;
          }

          uploadedFileName = fileName;
          const { data: { publicUrl } } = supabase.storage
            .from('facturas')
            .getPublicUrl(fileName);

          factura_image = publicUrl;
        }

        let primer_lugar_goles: number | null = null;
        let segundo_lugar_goles: number | null = null;

        if (predictFinalScore) {
          const primerGolesInput = document.getElementById('primer-lugar-goles') as HTMLInputElement | null;
          const segundoGolesInput = document.getElementById('segundo-lugar-goles') as HTMLInputElement | null;
          
          if (primerGolesInput && segundoGolesInput) {
            primer_lugar_goles = parseInt(primerGolesInput.value, 10);
            segundo_lugar_goles = parseInt(segundoGolesInput.value, 10);
            
            if (isNaN(primer_lugar_goles) || isNaN(segundo_lugar_goles) || primer_lugar_goles < 0 || segundo_lugar_goles < 0) {
              showError("Por favor, ingresa una cantidad de goles válida.");
              if (uploadedFileName) {
                await supabase.storage.from('facturas').remove([uploadedFileName]);
              }
              submitBtn.disabled = false;
              submitBtn.style.opacity = '1';
              spinner?.classList.add('hidden');
              return;
            }
          }
        }

        const { error } = await supabase
          .from('quiniela_participaciones')
          .insert([
            {
              sponsor_id: sponsorId,
              cedula,
              nombre,
              email,
              telefono,
              instagram_account: instagram,
              primer_lugar,
              segundo_lugar,
              tercer_lugar,
              factura_image,
              primer_lugar_goles,
              segundo_lugar_goles
            }
          ]);

        if (error) {
          if (uploadedFileName) {
            await supabase.storage.from('facturas').remove([uploadedFileName]);
          }

          if (error.code === '23505') { // Postgres unique violation
            showError("Ya existe una participación registrada con esta cédula.");
          } else {
            showError("Hubo un error al enviar tu participación. Inténtalo de nuevo.");
            console.error(error);
          }
        } else {
          // Success
          form.style.display = 'none';
          if (successDiv) successDiv.classList.remove('hidden');
        }
      } catch (err) {
        if (uploadedFileName) {
          try {
            await supabase.storage.from('facturas').remove([uploadedFileName]);
          } catch (_) {}
        }
        showError("Error de conexión. Revisa tu internet.");
      } finally {
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        spinner?.classList.add('hidden');
      }
    });
  });
</script>

